{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "method_version",
    "finding_assessment",
    "coverage_status",
    "summary",
    "scope",
    "findings",
    "uncertainties",
    "coverage",
    "next_steps"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "1.0"
      ]
    },
    "method_version": {
      "type": "string",
      "enum": [
        "1.0"
      ]
    },
    "finding_assessment": {
      "type": "string",
      "enum": [
        "material-findings",
        "no-material-findings"
      ]
    },
    "coverage_status": {
      "type": "string",
      "enum": [
        "sufficient",
        "limited",
        "insufficient"
      ]
    },
    "summary": {
      "type": "string"
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "uncertainties": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/uncertainty"
      }
    },
    "coverage": {
      "$ref": "#/$defs/coverage"
    },
    "next_steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/next_step"
      }
    }
  },
  "$defs": {
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "capability_modes",
        "base",
        "components",
        "intent_sources"
      ],
      "properties": {
        "target": {
          "type": "string"
        },
        "capability_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "supplied-context",
              "repository-read",
              "git-aware",
              "safe-exec"
            ]
          }
        },
        "base": {
          "$ref": "#/$defs/base_resolution"
        },
        "components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scope_component"
          }
        },
        "intent_sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/intent_source"
          }
        }
      }
    },
    "base_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch_component_available",
        "base_ref",
        "base_commit_oid",
        "merge_base_oid",
        "base_resolution_method",
        "remote_freshness",
        "notes"
      ],
      "properties": {
        "branch_component_available": {
          "type": "boolean"
        },
        "base_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "base_commit_oid": {
          "type": [
            "string",
            "null"
          ]
        },
        "merge_base_oid": {
          "type": [
            "string",
            "null"
          ]
        },
        "base_resolution_method": {
          "type": "string",
          "enum": [
            "user-specified",
            "host-review-base",
            "repository-review-base",
            "origin-head",
            "default-candidate",
            "unavailable",
            "not-applicable"
          ]
        },
        "remote_freshness": {
          "type": "string",
          "enum": [
            "verified",
            "local-only",
            "unknown",
            "not-applicable"
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "scope_component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "status",
        "description",
        "paths",
        "reason"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "branch-diff",
            "index-overlay",
            "worktree-overlay",
            "untracked-candidate",
            "supplied-context"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "included",
            "excluded",
            "unavailable"
          ]
        },
        "description": {
          "type": "string"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "intent_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path",
        "detail"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user-prompt",
            "commit-message",
            "pr-description",
            "issue",
            "test-name",
            "code-comment",
            "inferred"
          ]
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "scope_components",
        "severity",
        "confidence",
        "finding_level",
        "risk_domains",
        "primary_lens",
        "title",
        "type",
        "change_relation",
        "delta_evidence",
        "causal_trace",
        "body",
        "locations",
        "evidence",
        "assumptions",
        "verification",
        "recommendation"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "scope_components": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "severity": {
          "type": "string",
          "enum": [
            "critical",
            "high",
            "medium"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium"
          ]
        },
        "finding_level": {
          "type": "string",
          "enum": [
            "implementation",
            "design",
            "operability"
          ]
        },
        "risk_domains": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lens_name"
          }
        },
        "primary_lens": {
          "$ref": "#/$defs/lens_name"
        },
        "title": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "implementation",
            "design",
            "operability",
            "security",
            "data",
            "compatibility",
            "concurrency",
            "resource",
            "llm-agent"
          ]
        },
        "change_relation": {
          "type": "string",
          "enum": [
            "introduced",
            "worsened",
            "exposed",
            "proposed"
          ]
        },
        "delta_evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/delta_evidence"
          }
        },
        "causal_trace": {
          "$ref": "#/$defs/causal_trace"
        },
        "body": {
          "type": [
            "string",
            "null"
          ]
        },
        "locations": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/source_location"
              },
              {
                "$ref": "#/$defs/command_evidence"
              },
              {
                "$ref": "#/$defs/missing_control"
              }
            ]
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_item"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verification": {
          "$ref": "#/$defs/verification"
        },
        "recommendation": {
          "type": "string"
        }
      }
    },
    "delta_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "detail",
        "location_ref"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "new-reachable-path",
            "expanded-blast-radius",
            "guard-weakened",
            "likelihood-increased",
            "impact-increased",
            "external-contract-changed",
            "proposed-failure-path"
          ]
        },
        "detail": {
          "type": "string"
        },
        "location_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "causal_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preconditions",
        "trigger",
        "reachable_path",
        "failed_guard_or_transition",
        "violated_invariant",
        "impact"
      ],
      "properties": {
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "trigger": {
          "type": "string"
        },
        "reachable_path": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failed_guard_or_transition": {
          "type": "string"
        },
        "violated_invariant": {
          "type": "string"
        },
        "impact": {
          "type": "string"
        }
      }
    },
    "source_location": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "path",
        "line_start",
        "line_end",
        "detail"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "source",
            "config",
            "test",
            "contract"
          ]
        },
        "path": {
          "type": "string"
        },
        "line_start": {
          "type": "integer"
        },
        "line_end": {
          "type": "integer"
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "command_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "display_command",
        "command_digest",
        "digest_algorithm",
        "digest_source",
        "command_origin",
        "exit_code",
        "output_digest",
        "relevant_excerpt",
        "redaction_applied",
        "redaction_note"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "command"
          ]
        },
        "display_command": {
          "type": "string"
        },
        "command_digest": {
          "type": [
            "string",
            "null"
          ]
        },
        "digest_algorithm": {
          "type": "string",
          "enum": [
            "sha256"
          ]
        },
        "digest_source": {
          "type": "string",
          "enum": [
            "host-computed",
            "agent-reported",
            "not-available"
          ]
        },
        "command_origin": {
          "type": "string",
          "enum": [
            "reviewer-executed",
            "host-supplied",
            "user-supplied"
          ]
        },
        "exit_code": {
          "type": "integer"
        },
        "output_digest": {
          "type": [
            "string",
            "null"
          ]
        },
        "relevant_excerpt": {
          "type": "string"
        },
        "redaction_applied": {
          "type": "boolean"
        },
        "redaction_note": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "missing_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "expected_anchor",
        "searched_scope",
        "search_method",
        "supporting_paths",
        "detail"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "missing-control"
          ]
        },
        "expected_anchor": {
          "type": "string"
        },
        "searched_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "search_method": {
          "type": "string"
        },
        "supporting_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "detail",
        "location_ref"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "code-trace",
            "contract",
            "configuration",
            "test",
            "command",
            "documentation",
            "absence-search"
          ]
        },
        "detail": {
          "type": "string"
        },
        "location_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checks_performed",
        "refutations_checked",
        "remaining_gaps"
      ],
      "properties": {
        "checks_performed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "refutations_checked": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "remaining_gaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_components",
        "risk",
        "missing_evidence",
        "materiality_if_true",
        "recommended_check"
      ],
      "properties": {
        "scope_components": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risk": {
          "type": "string"
        },
        "missing_evidence": {
          "type": "string"
        },
        "materiality_if_true": {
          "type": "string"
        },
        "recommended_check": {
          "type": "string"
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lenses_considered",
        "lenses_applied",
        "lenses_skipped_with_reason",
        "checks_performed",
        "component_coverage",
        "limitations",
        "sensitive_artifacts"
      ],
      "properties": {
        "lenses_considered": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lens_name"
          }
        },
        "lenses_applied": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lens_name"
          }
        },
        "lenses_skipped_with_reason": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/skipped_lens"
          }
        },
        "checks_performed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "component_coverage": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/component_coverage"
          }
        },
        "limitations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/coverage_limitation"
          }
        },
        "sensitive_artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sensitive_artifact"
          }
        }
      }
    },
    "component_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_components",
        "status",
        "checks_performed",
        "reason"
      ],
      "properties": {
        "scope_components": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "evaluated",
            "skipped",
            "unavailable"
          ]
        },
        "checks_performed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "lens_name": {
      "type": "string",
      "enum": [
        "security-trust",
        "data-state",
        "concurrency-distributed",
        "compatibility-migration",
        "resilience-operability",
        "resource-safety",
        "llm-agent"
      ]
    },
    "skipped_lens": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lens",
        "reason"
      ],
      "properties": {
        "lens": {
          "$ref": "#/$defs/lens_name"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "coverage_limitation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "detail",
        "scope_components"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "missing-capability",
            "unavailable-base",
            "stale-remote",
            "unreadable-artifact",
            "oversized-artifact",
            "binary-artifact",
            "generated-artifact",
            "sensitive-artifact",
            "unsafe-command",
            "network-unavailable",
            "time-budget"
          ]
        },
        "detail": {
          "type": "string"
        },
        "scope_components": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "sensitive_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "classification",
        "handling",
        "detail"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "classification": {
          "type": "string",
          "enum": [
            "secret-like",
            "credential",
            "private-key",
            "keystore",
            "production-dump",
            "customer-data",
            "incident-log",
            "pii",
            "unknown-sensitive"
          ]
        },
        "handling": {
          "type": "string",
          "enum": [
            "metadata-only",
            "redacted",
            "excluded",
            "user-authorized"
          ]
        },
        "detail": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "next_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "detail",
        "scope_components"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "fix",
            "verify",
            "gather-evidence",
            "clarify-scope",
            "run-safe-command",
            "policy-decision"
          ]
        },
        "detail": {
          "type": "string"
        },
        "scope_components": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
